PORT=8000
DATABASE_URL=mysql://user:password@localhost:3306/your_database
# Used for CORS in production. In NODE_ENV=development the API reflects any Origin (any Next port).
# Comma-separated origins if you need multiple in production.
FRONTEND_URL=http://localhost:3000
JWT_SECRET=change_me_min_16_chars_secret
JWT_EXPIRES_IN=7d
# Natural language cart (retailer). Server-side only — never expose to the browser.
OPENAI_API_KEY=
# Optional: defaults to gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# After DB is migrated, load demo catalog for all distributor accounts:
# npm run seed:mock-products

# V1 batch / delivery (see docs/V1-DELIVERY-BATCH-SPEC.md)
BATCH_WINDOW_MINUTES=30
ROLLING_GAP_MINUTES=30
APP_TIMEZONE=Asia/Kolkata
EARLY_CLOSE_ENABLED=false
# Optional: pin which user (role=delivery_partner) gets runs & early-close capacity checks
# DEFAULT_DELIVERY_PARTNER_ID=1

# After migration, seed Ahmedabad demo sites:
# npm run seed:delivery-sites
